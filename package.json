{
  "name": "vite-ts-tailwindcss-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --open",
    "format": "prettier --write .",
    "format:check": "prettier . --check",
    "format:lint": "pnpm run format && pnpm run lint",
    "lint": "eslint .",
    "build": "pnpm run format:lint && npx tsc -b && vite build",
    "preview": "vite preview --host --open",
    "build:preview": "pnpm run build && pnpm run preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.574.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-dom": "^2.13.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-react-x": "^2.13.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.2"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "minimatch@3>brace-expansion": "^1.1.13",
      "minimatch@10>brace-expansion": ">=5.0.5"
    }
  }
}
